# Copy this file to .env and replace the placeholder with your actual key.
# .env is listed in .gitignore — never commit your real key.
#
# Get a free Groq API key (no credit card required) at:
# https://console.groq.com

GROQ_API_KEY=your_key_here

# Reddit API (create a "script" app at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=unofficial-guide/0.1 by u/yourusername
